# ── API URL ───────────────────────────────────
# Development
NEXT_PUBLIC_API_URL=http://localhost:4000

# Production — Railway üzerindeki API servisinin URL'i
# NEXT_PUBLIC_API_URL=https://mei-api.railway.app

# ── Discord OAuth2 ────────────────────────────
