# ── Database ──────────────────────────────────
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/meibot

# ── JWT ───────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars

# ── Discord OAuth2 ────────────────────────────
DISCORD_CLIENT_ID=your_discord_application_client_id
DISCORD_CLIENT_SECRET=your_discord_application_client_secret
# Must match exactly what is set in Discord Developer Portal > OAuth2 > Redirects
DISCORD_REDIRECT_URI=http://localhost:4000/api/auth/discord/callback

# ── URLs ──────────────────────────────────────
FRONTEND_URL=http://localhost:3000
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000

# ── Server ────────────────────────────────────
PORT=4000
NODE_ENV=development
