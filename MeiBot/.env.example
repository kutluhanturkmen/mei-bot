# =============================================
# 🌸 MEI BOT — ENVIRONMENT VARIABLES
# =============================================
# Bu dosyayı asla Git'e commit etme!
# .gitignore dosyasına .env eklemeyi unutma.

# Discord Bot Token (Discord Developer Portal'dan al)
DISCORD_TOKEN=YOU_BOT_TOKEN

# Discord Application ID (Developer Portal > General Information)
CLIENT_ID=YOUR_CLIENT_ID

# MongoDB Connection URI (MongoDB Atlas veya local)
MONGO_URI=MONG_DB_URL

# (Opsiyonel) Test sunucusu ID'si — geliştirme aşamasında komutlar buraya kayıt edilir
GUILD_ID=TEST_GUILD_ID
